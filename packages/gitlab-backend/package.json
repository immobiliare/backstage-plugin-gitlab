        "@backstage/plugin-catalog-node": "^2.1.0",
        "@types/express": "^4.17.21",
        "@types/supertest": "^6.0.2",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "msw": "^2.7.1",
        "supertest": "^6.3.4"
